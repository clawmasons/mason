{
  "name": "@clawmasons/shared",
  "version": "0.1.0",
  "description": "Shared types, schemas, and utilities for mason command line",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
