{
  "name": "@clawmasons/mason",
  "version": "0.1.0",
  "description": "Mason — AI agent packaging, governance, and runtime orchestration",
  "type": "module",
  "bin": {
    "mason": "dist/cli/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:proxy": "tsx esbuild.proxy.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0"
  },
  "files": [
    "dist",
    "templates"
  ],
  "license": "MIT",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.0",
    "@clawmasons/shared": "*",
    "@clawmasons/agent-sdk": "*",
    "@clawmasons/claude-code": "*",
    "@clawmasons/pi-coding-agent": "*",
    "@clawmasons/proxy": "*",
    "@clawmasons/credential-service": "*",
    "commander": "^14.0.3"
  }
}
