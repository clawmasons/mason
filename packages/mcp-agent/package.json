{
  "name": "@clawmasons/mcp-agent",
  "version": "0.1.5",
  "description": "General-purpose MCP agent with REPL and ACP modes for testing and debugging the mason proxy pipeline",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./agent-package": {
      "import": "./dist/agent-package.js",
      "types": "./dist/agent-package.d.ts"
    }
  },
  "bin": {
    "mcp-agent": "./dist/mcp-agent.js"
  },
  "scripts": {
    "build": "tsx esbuild.config.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.0",
    "@clawmasons/agent-sdk": "^0.1.5",
    "@clawmasons/shared": "^0.1.5"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0"
  }
}
