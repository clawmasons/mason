{
  "name": "@clawmasons/agent-sdk",
  "version": "0.1.6",
  "description": "SDK for building Mason agent packages",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "fixtures"
  ],
  "license": "MIT",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.0",
    "@clawmasons/shared": "^0.1.6",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
