{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "paths": {
      "@clawmasons/shared": ["./packages/shared/src/index.ts"],
      "@clawmasons/proxy": ["./packages/proxy/src/index.ts"],

      "@clawmasons/agent-entry": ["./packages/agent-entry/src/index.ts"],
      "@clawmasons/agent-sdk": ["./packages/agent-sdk/src/index.ts"],
      "@clawmasons/agent-sdk/testing": ["./packages/agent-sdk/src/testing/index.ts"],
      "@clawmasons/mcp-agent": ["./packages/mcp-agent/src/index.ts"],
      "@clawmasons/mcp-agent/agent-package": ["./packages/mcp-agent/src/agent-package.ts"]
    }
  },
  "include": [
    "packages/shared/src/**/*",
    "packages/proxy/src/**/*",
    "packages/cli/src/**/*",
    "packages/agent-entry/src/**/*",
    "packages/mcp-agent/src/**/*",
    "packages/proxy/tests/**/*",
    "packages/cli/tests/**/*",
    "packages/agent-entry/tests/**/*",
    "packages/shared/tests/**/*",
    "packages/mcp-agent/tests/**/*",
    "packages/agent-sdk/src/**/*",
    "packages/agent-sdk/tests/**/*"
  ]
}
