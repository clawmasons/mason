{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "paths": {
      "@clawmasons/shared": ["./packages/shared/src/index.ts"],
      "@clawmasons/proxy": ["./packages/proxy/src/index.ts"]
    }
  },
  "include": [
    "packages/shared/src/**/*",
    "packages/proxy/src/**/*",
    "packages/cli/src/**/*",
    "packages/proxy/tests/**/*",
    "packages/cli/tests/**/*"
  ]
}
