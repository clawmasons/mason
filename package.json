{
  "name": "@clawmasons/chapter-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Clawmasons Chapter — npm-native packaging, governance, and runtime portability for AI agents",
  "type": "module",
  "scripts": {
    "build": "tsc -b packages/shared packages/proxy packages/cli",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/*/src/ packages/*/tests/",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "!packages/placeholders",
    "e2e"
  ],
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.0"
  }
}
