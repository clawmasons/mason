{
  "name": "@clawforge/pam",
  "version": "0.1.0",
  "description": "Packaged Agent Manager — npm-native packaging, governance, and runtime portability for AI agents",
  "type": "module",
  "bin": {
    "pam": "./bin/pam.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "mcp",
    "npm",
    "governance"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.3.3",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^3.24.0"
  }
}
